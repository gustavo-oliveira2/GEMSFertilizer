Package: GEMSFertilizer
Title: Sistema de Recomendacao de Adubacao e Calagem para Culturas Agricolas
Version: 0.3.0
Date: 2026-06-16
Authors@R: 
    person(
      given   = "GEMS",
      family  = "Research Group",
      role    = c("aut", "cre"),
      email   = "gustavooliveira@academico.ufs.br",
      comment = c(ORCID = "0000-0002-3839-6261")
